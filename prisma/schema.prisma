generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Reservation {
  id              String   @id @default(cuid())
  status          String   @default("upcoming")
  createdAt       DateTime @default(now())
  stripeSessionId String?  @unique
  vehicleId       String
  vehicleTitle    String
  vehicleImage    String
  checkIn         String
  checkOut        String
  nights          Int
  price           Int
  subtotal        Int
  taxes           Int
  total           Int
  firstName       String
  lastName        String
  email           String
  phone           String
  airportFee      Int      @default(0)
  dropoffLocation String   @default("")
  insuranceFee    Int      @default(0)
  notes           String   @default("")

  @@index([status])
  @@index([vehicleId])
  @@index([email])
  @@index([createdAt])
}

model Vehicle {
  id           String   @id @default(cuid())
  title        String
  price        Int
  capacity     Int
  description  String
  amenities    String[]
  images       String[]
  imageBlurs   String[]  @default([])
  location     String
  rating       Float    @default(4.7)
  reviewCount  Int      @default(0)
  minNights    Int      @default(2)
  bookedRanges Json     @default("[]")
  reviews      Json     @default("[]")
  paused       Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([paused])
  @@index([createdAt])
}

model SiteContent {
  id        String   @id @default("main")
  data      Json     @default("{}")
  updatedAt DateTime @updatedAt
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
  attempts  Int      @default(0)

  @@index([email])
  @@index([expiresAt])
}
